# Copy to .env.local and fill in. .env.local is git-ignored.
# KIE (kie.ai) API key for image generation (server-side / build scripts only).
KIE_API_KEY=

# Optional overrides
# KIE_BASE_URL=https://api.kie.ai
# KIE_MODEL=

# Groq API key for the "Ask about Jaimes" chatbot (server-side only).
# Get it from https://console.groq.com — do NOT prefix with VITE_.
GROQ_API_KEY=
# Optional overrides (defaults shown):
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
